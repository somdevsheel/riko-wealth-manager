# Riko backend environment

# Set to 1 to enable the real LLM+RAG path in app/engines/advisor.py.
# Requires Ollama running locally with the model below pulled
# (`ollama pull qwen2.5:7b-instruct`). Falls back to the rule-based responder
# if unset, unreachable, or on any error — the demo never breaks.
LLM_ENABLED=0
LLM_MODEL=qwen2.5:7b-instruct
OLLAMA_BASE_URL=http://localhost:11434

# Chroma persists the embedded financial-context documents here.
CHROMA_DIR=chroma_store

# Postgres: transactions, goals, profiles, wealth-score history.
# Native local install default (see backend/README.md). Under docker-compose
# this is overridden to postgresql+psycopg2://riko:riko@postgres:5432/riko
DATABASE_URL=postgresql+psycopg2://postgres:riko_dev_pw@localhost:5432/riko

# MongoDB: Artha conversation history + generated insight snapshots.
# Under docker-compose this is overridden to mongodb://mongo:27017
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=riko
